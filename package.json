{
  "name": "vue-mathjax-beautiful-monorepo",
  "version": "1.3.4",
  "description": "🚀 精简、高效的 Vue 3 数学公式编辑器组件库",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "dev:vue": "pnpm --filter playground dev",
    "dev:react": "pnpm --filter playground dev",
    "build": "pnpm --filter @vue-mathjax-beautiful/shared build && pnpm --filter vue-mathjax-beautiful build && pnpm --filter react-mathjax-beautiful build",
    "build:all": "pnpm -r build",
    "type-check": "pnpm --filter @vue-mathjax-beautiful/shared type-check && pnpm --filter vue-mathjax-beautiful type-check && pnpm --filter react-mathjax-beautiful type-check && pnpm --filter playground exec vue-tsc && pnpm type-check:api",
    "type-check:api": "pnpm type-check:api:vue && pnpm type-check:api:react",
    "type-check:api:vue": "vue-tsc --noEmit -p tsconfig.type-tests.vue.json",
    "type-check:api:react": "tsc --noEmit -p tsconfig.type-tests.react.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --fix",
    "format": "prettier --write packages/*/src/**/*.{vue,ts,tsx,js,css} examples/*/src/**/*.{vue,ts,tsx,js,css}",
    "prepare": "husky install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:all && changeset publish"
  },
  "keywords": [
    "vue",
    "math",
    "editor",
    "mathjax",
    "formula",
    "typescript"
  ],
  "author": "不讲道理的柯里昂 <15096061897@163.com>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@eslint/js": "^10.0.1",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node18": "^18.2.2",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^18.19.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-vue": "^9.17.0",
    "husky": "^8.0.3",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.3",
    "typescript": "~5.3.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.10",
    "vitest": "^1.0.4",
    "vue": "^3.3.11",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^1.8.25"
  }
}
